# LLMOps 本地开发环境配置
# 使用本地 PostgreSQL 和 Redis，Docker 仅运行 Weaviate
# 复制此文件为 .env 并根据实际情况修改配置

# 数据库配置 (本地 PostgreSQL)
# 请根据您的实际 PostgreSQL 配置修改用户名和密码
SQLALCHEMY_DATABASE_URI=postgresql://postgres:your_password@localhost:5432/llmops
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=True

# Redis 配置 (本地 Redis)
# 请根据您的实际 Redis 配置修改
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
CELERY_BROKER_DB=1
CELERY_RESULT_BACKEND_DB=1
CELERY_TASK_IGNORE_RESULT=False
CELERY_RESULT_EXPIRES=3600
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True

# Flask 配置
WTF_CSRF_ENABLED=False
ASSISTANT_AGENT_ID=6774fcef-b594-8008-b30c-a05b8190afe6
JWT_SECRET_KEY=please-change-me-in-production

# OpenAI API 配置
# 请替换为您的实际 OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Weaviate 向量数据库配置 (Docker 容器)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080

# Flask 应用配置
FLASK_ENV=development
FLASK_DEBUG=1
